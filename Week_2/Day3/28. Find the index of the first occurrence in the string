class Solution {
public:
    int strStr(string haystack, string needle) {
        int n = haystack.size();
        int m = needle.size();

        for (int i = 0; i < n; i++) {
            int j = 0;

            for (int k = i; k < n; k++) {
                if (j < m && haystack[k] == needle[j]) {
                    j++;
                } else {
                    break;
                }

                if (j == m) {
                    return i;
                }
            }
        }

        return -1;
    }
};
