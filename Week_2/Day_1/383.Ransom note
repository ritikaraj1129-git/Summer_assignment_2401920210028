class Solution {
public:
    bool canConstruct(string ransomNote, string magazine) {
        unordered_map<char,int> x;
        
        for( char c : magazine){
            x[c]++;
        }
        for(char c : ransomNote){
            if(x[c]==0){
                return false;
            }
            x[c]--;
        }
        return true;
    }
};
