class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        int m= mat.size() ;
        int n = mat[0].size();

        if (m * n != r * c) {
            return mat;
        }

        vector<vector<int>> res(r, vector<int>(c));

        for (int k = 0; k < m * n; k++) {
            res[k / c][k % c] = mat[k / n][k % n];
        }

        return res;
    }
};
